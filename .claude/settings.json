{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/openspec-validate.ts\"",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bd *)",
      "Bash(bun x openspec *)",
      "Bash(bunx openspec *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git rm *)",
      "Bash(git checkout -b *)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(bun run lint)",
      "Bash(bun run typecheck)",
      "Bash(bun run test)",
      "Bash(bun run test:coverage)",
      "Bash(bun test)",
      "Bash(bun test *)",
      "mcp__stitch__list_projects",
      "mcp__stitch__get_project",
      "mcp__stitch__create_project",
      "mcp__stitch__list_screens",
      "mcp__stitch__get_screen",
      "mcp__stitch__generate_screen_from_text",
      "mcp__stitch__generate_variants",
      "mcp__stitch__edit_screens",
      "mcp__stitch__list_design_systems",
      "mcp__stitch__create_design_system",
      "mcp__stitch__update_design_system",
      "mcp__stitch__apply_design_system",
      "mcp__stitch__upload_design_md",
      "mcp__stitch__create_design_system_from_design_md"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr comment *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git push --force*)",
      "Bash(rm -rf*)",
      "mcp__stitch__delete_project"
    ]
  }
}
