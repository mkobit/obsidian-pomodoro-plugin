# vscode
.vscode

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# vitest coverage
coverage

# Exclude macOS Finder (System Explorer) View States
.DS_Store
.obsidian-cache/

# Playwright & Integration testing
playwright-report/
test-results/
.obsidian-bin/
e2e/test-vault/
# Plugin install artifacts inside the example vault — populated at runtime by vault:install
routine-flow-example-vault/.obsidian/plugins/
# Generated per-routine vault content — written by e2e/vault/generator.ts (flow-94c),
# via e2e/global-setup.ts before e2e runs, or `bun scripts/vault-dev.ts --generated`
routine-flow-example-vault/pomodoro/
routine-flow-example-vault/standup/
routine-flow-example-vault/workout/
routine-flow-example-vault/spaced-repetition/
routine-flow-example-vault/stretch-break/
routine-flow-example-vault/habit-tracking/

# Claude Code local-only settings
.claude/settings.local.json

# Stray build output capture
build_output.log

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Beads exports — bd dolt push/pull (refs/dolt/data on origin) is the durable
# sync path; these are just local passive exports for scripting/grep, not
# needed in git. config.yaml/metadata.json/README.md/hooks stay tracked.
.beads/issues.jsonl
.beads/interactions.jsonl
